# ASRH: Agent Safety Regression Harness
# Copy this file to `.env` for local development:
#
#   cp .env.example .env
#
# `.env` is ignored by git. Do not commit real API keys, provider tokens,
# credentials, private datasets, real emails, or real secrets. ASRH test cases
# should use synthetic secrets only, e.g. `sk-test-DO-NOT-REVEAL`.

# -----------------------------------------------------------------------------
# Provider credentials
# -----------------------------------------------------------------------------
# Mock-mode runs do not require provider credentials.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional provider overrides for OpenAI-compatible gateways or test doubles.
OPENAI_BASE_URL=
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=
ANTHROPIC_BASE_URL=

# -----------------------------------------------------------------------------
# Default model and run configuration
# -----------------------------------------------------------------------------
ASRH_ENV=development
ASRH_LOG_LEVEL=INFO
ASRH_DEFAULT_MODEL=mock/safe
ASRH_DEFAULT_UNSAFE_MODEL=mock/unsafe_leaker
ASRH_DEFAULT_REAL_MODEL=openai/gpt-4o-mini
ASRH_DEFAULT_MITIGATION=none
ASRH_GUARD_MITIGATION=tool_policy_guard

ASRH_SUITE_DIR=suites
ASRH_RUN_DIR=runs
ASRH_REPORT_DIR=reports

ASRH_TEMPERATURE=0.0
ASRH_SEED=0
ASRH_MAX_STEPS=8
ASRH_MAX_TOOL_CALLS=6
ASRH_MAX_TOKENS_PER_RESPONSE=800
ASRH_MAX_TOTAL_TOKENS=6000
ASRH_TIMEOUT_SECONDS=60
ASRH_FAIL_FAST=false

# -----------------------------------------------------------------------------
# Provider request behavior
# -----------------------------------------------------------------------------
ASRH_HTTP_TIMEOUT_SECONDS=60
ASRH_HTTP_MAX_RETRIES=3
ASRH_HTTP_RETRY_MIN_SECONDS=1
ASRH_HTTP_RETRY_MAX_SECONDS=20

# Keep false in CI and mock-only development.
ASRH_ENABLE_PROVIDER_RUNS=false

# -----------------------------------------------------------------------------
# MVP tool safety gates
# -----------------------------------------------------------------------------
# The MVP spec requires simulated tools by default. Keep these false unless a
# future sandbox-safe implementation explicitly documents otherwise.
ASRH_ALLOW_REAL_SHELL=false
ASRH_ALLOW_REAL_EMAIL=false
ASRH_ALLOW_REAL_NETWORK=false
ASRH_ALLOW_REAL_CREDENTIALS=false
ASRH_ALLOW_BROWSER_AUTOMATION=false

# Simulated high-risk actions should deny by default unless a case explicitly
# configures authorization or a mitigation simulates human approval.
ASRH_REQUIRE_HUMAN_APPROVAL_FOR_SEND_EMAIL=true
ASRH_REQUIRE_HUMAN_APPROVAL_FOR_RUN_SHELL=true
ASRH_REQUIRE_HUMAN_APPROVAL_FOR_SENSITIVE_READ=true
ASRH_DEFAULT_DENY_SENSITIVE_FILE_ACCESS=true

# -----------------------------------------------------------------------------
# Trace, report, and redaction behavior
# -----------------------------------------------------------------------------
ASRH_TRACE_FORMAT=jsonl
ASRH_TRACE_MESSAGES=true
ASRH_TRACE_TOOL_OUTPUTS=true
ASRH_TRACE_POLICY_DECISIONS=true
ASRH_REDACT_SECRETS_IN_LOGS=true
ASRH_REDACTION_PLACEHOLDER=[REDACTED]
ASRH_REDACT_SYSTEM_PROMPTS=false
ASRH_INCLUDE_COST_ESTIMATES=true
ASRH_ALLOW_REAL_SECRETS_IN_CASES=false
ASRH_SYNTHETIC_SECRET_PREFIXES=sk-test,DEPLOY_TOKEN,PRIVATE_KEY,API_KEY
ASRH_ARTIFACT_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# Optional local model settings
# -----------------------------------------------------------------------------
ASRH_LOCAL_MODEL_ID=
ASRH_LOCAL_MODEL_PATH=
ASRH_LOCAL_DEVICE=auto
ASRH_LOCAL_DTYPE=auto
ASRH_HF_TOKEN=
ASRH_HF_HOME=.cache/huggingface
TOKENIZERS_PARALLELISM=false

# -----------------------------------------------------------------------------
# Development and CI
# -----------------------------------------------------------------------------
PYTHONHASHSEED=0
PYTHONUTF8=1
PYTHONWARNINGS=error
PYTEST_ADDOPTS=
ASRH_DISABLE_TELEMETRY=true
ASRH_CI=false
